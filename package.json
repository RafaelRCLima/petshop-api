{
  "name": "petshop",
  "version": "1.0.0",
  "description": "Sistema de agendamento de serviços para Petshop.",
  "main": "index.js",
  "author": "Rafael lima",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "nodemon ./src/app.ts",
    "dev": "tsx watch --env-file .env ./src/app.ts",
    "debug": "tsx --env-file .env --inspect-brk ./src/app.ts",
    "lint": "eslint . --ext .ts",
    "pretest": "dotenv -e .env.test -- prisma migrate deploy",
    "test": "dotenv -e .env.test -- node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand --detectOpenHandles"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7",
    "@types/node": "^24.5.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.36.0",
    "express": "^5.1.0",
    "nvm": "^0.0.4",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "tsx": "^4.20.6",
    "winston": "^3.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "dotenv": "^16.6.1",
    "globals": "^16.4.0",
    "jest": "^30.2.0",
    "jiti": "^2.6.0",
    "prisma": "^7",
    "sucrase": "^3.35.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  }
}
